# Variables d'environnement — Copier en .env et remplir les valeurs

# Clé API Mistral (optionnel — mocks disponibles sans clé)
MISTRAL_API_KEY=

# URL Ollama (fallback LLM local)
OLLAMA_URL=http://localhost:11434

# Modèle Whisper pour la transcription audio (tiny/base/small/medium/large)
WHISPER_MODEL=small

# URL de la base de données SQLite
DATABASE_URL=sqlite:///./khidmati.db

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:3000
